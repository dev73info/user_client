    "dompurify": "^3.4.2",
    "element-plus": "^2.13.7",
    "markdown-it": "^14.1.1",
    "pinia": "^3.0.4",
    "qrcode": "^1.5.4",
    "tags-wasm": "link:../tags-wasm/pkg",
    "vue": "^3.5.31",
    "vue-router": "^4.3.9"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tsconfig/node24": "^24.0.4",
    "@types/jsdom": "^28.0.1",
